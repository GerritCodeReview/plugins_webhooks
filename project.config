[access]
	inheritFrom = Public-Plugins
[access "refs/*"]
	owner = group google/gerritcodereview-maintainers@googlegroups.com
	owner = group plugins-webhooks
[project]
	description = This plugin allows to propagate Gerrit events to remote http endpoints.
[access "refs/heads/stable-3.10"]
	delete = group google/gerritcodereview-maintainers@googlegroups.com
